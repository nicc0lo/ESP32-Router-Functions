#include <Arduino.h>
#include <WiFi.h>
#include <WebServer.h>
#include <vector>
#include "esp_wifi.h"

// --- Configuration ---
#define AP_SSID         "ESP32_Secure_Net"
#define AP_PASSWORD     "gatekeeper"
#define MAX_STA_CONN    10

std::vector<String> trusted_macs = {
    "52:A3:59:D2:B4:72", // Your Trusted Laptop
    "11:22:33:44:55:66"
};

WebServer server(80);

// --- Helpers ---

bool is_mac_trusted(uint8_t* mac) {
    char buf[18];
    sprintf(buf, "%02X:%02X:%02X:%02X:%02X:%02X", mac[0], mac[1], mac[2], mac[3], mac[4], mac[5]);
    for (const String& s : trusted_macs) {
        if (s.equalsIgnoreCase(buf)) return true;
    }
    return false;
}

// Security: Only allow Trusted MACs to access the Web Server
bool checkAuth() {
    uint8_t remote_mac[6];
    wifi_sta_list_t sta_list;
    esp_wifi_ap_get_sta_list(&sta_list);
    
    // Check if the requester's IP matches a trusted MAC in the current station list
    for (int i = 0; i < sta_list.num; i++) {
        if (is_mac_trusted(sta_list.sta[i].mac)) return true;
    }
    return false;
}

// --- Web Handlers ---

void handleRoot() {
    if (!checkAuth()) {
        server.send(403, "text/plain", "ACCESS DENIED: Untrusted Hardware.");
        return;
    }

    String html = "<html><head><meta name='viewport' content='width=device-width, initial-scale=1'><style>";
    html += "body { font-family: sans-serif; background: #121212; color: #e0e0e0; text-align: center; }";
    html += ".container { max-width: 500px; margin: auto; padding: 20px; }";
    html += ".client-card { background: #1e1e1e; border: 1px solid #333; padding: 15px; margin: 10px 0; border-radius: 8px; display: flex; justify-content: space-between; align-items: center; }";
    html += ".btn { background: #ff5252; color: white; border: none; padding: 8px 15px; border-radius: 5px; cursor: pointer; text-decoration: none; }";
    html += ".trusted { border-left: 5px solid #4caf50; }";
    html += ".untrusted { border-left: 5px solid #ff9800; }";
    html += "</style></head><body><div class='container'>";
    html += "<h1>🛡️ Gatekeeper Admin</h1><hr>";
    
    wifi_sta_list_t sta_list;
    esp_wifi_ap_get_sta_list(&sta_list);
    
    html += "<h3>Active Stations: " + String(sta_list.num) + "</h3>";
    
    for (int i = 0; i < sta_list.num; i++) {
        char buf[20];
        uint8_t* m = sta_list.sta[i].mac;
        sprintf(buf, "%02X:%02X:%02X:%02X:%02X:%02X", m[0], m[1], m[2], m[3], m[4], m[5]);
        bool trusted = is_mac_trusted(m);
        
        html += "<div class='client-card " + String(trusted ? "trusted" : "untrusted") + "'>";
        html += "<div><strong>" + String(buf) + "</strong><br><small>" + String(trusted ? "ADMIN" : "GUEST") + "</small></div>";
        
        if (!trusted) {
            // Button links to /kick with the AID as a parameter
            html += "<a href='/kick?aid=" + String(i + 1) + "' class='btn'>KICK</a>";
        }
        html += "</div>";
    }
    
    html += "</div></body></html>";
    server.send(200, "text/html", html);
}

void handleKick() {
    if (!checkAuth()) return;
    if (server.hasArg("aid")) {
        int aid = server.arg("aid").toInt();
        esp_wifi_deauth_sta(aid);
        Serial.printf("[ADMIN] Manually kicked AID: %d\n", aid);
    }
    server.sendHeader("Location", "/");
    server.send(303); // Redirect back to home
}

// --- Sniffer ---

void packet_handler(void *buf, wifi_promiscuous_pkt_type_t type) {
    if (type != WIFI_PKT_DATA) return;
    wifi_promiscuous_pkt_t *pkt = (wifi_promiscuous_pkt_t *)buf;
    uint8_t *payload = pkt->payload;
    uint8_t *transmitter_mac = payload + 10; 

    uint8_t subtype = (payload[0] >> 4) & 0x0F;
    int offset = (subtype == 0x08) ? 34 : 32; 
    uint8_t *ip = payload + offset;

    if (ip[0] == 0x45) { // IPv4
        uint8_t ttl = ip[8];
        if (ttl == 63 || ttl == 127 || ttl == 254) {
            if (!is_mac_trusted(transmitter_mac)) {
                wifi_sta_list_t sta_list;
                esp_wifi_ap_get_sta_list(&sta_list);
                for (int i = 0; i < sta_list.num; i++) {
                    if (memcmp(sta_list.sta[i].mac, transmitter_mac, 6) == 0) {
                        Serial.printf("[AUTO-BLOCK] Tethering caught from " MACSTR "\n", MAC2STR(transmitter_mac));
                        esp_wifi_deauth_sta(i + 1); 
                    }
                }
            }
        }
    }
}

// --- Setup & Loop ---

void setup() {
    Serial.begin(115200);
    esp_wifi_set_ps(WIFI_PS_NONE); 
    
    WiFi.mode(WIFI_AP);
    WiFi.softAP(AP_SSID, AP_PASSWORD, 1); // Locked to Channel 1

    server.on("/", handleRoot);
    server.on("/kick", handleKick);
    server.begin();

    esp_wifi_set_promiscuous(true);
    esp_wifi_set_promiscuous_rx_cb(&packet_handler);

    Serial.println("🛡️ Admin Portal & Sniffer Active");
}

void loop() {
    server.handleClient(); // Critical for web server to work
}
